# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/profiles_db

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Profile Intelligence Service
APP_VERSION=2.0.0

# ─── Internal One-Time Seed Endpoint ─────────────────────────────────────────
# Keep disabled by default. Enable only when you need to run the one-time seed.
INTERNAL_SEED_ENABLED=false
# Set a strong secret token before enabling the endpoint.
INTERNAL_SEED_TOKEN=change-me
# Relative to project root, or an absolute path.
INTERNAL_SEED_FILE=seed_profiles.json
